#!/usr/bin/env bash
# Secret guard: blocks a commit if any STAGED change looks like a real credential.
#
# Install once per clone:
#     git config core.hooksPath scripts
# (or copy this file to .git/hooks/pre-commit and chmod +x it)
#
# Detection is STRUCTURAL — it flags a credential field that has been filled in
# with a non-placeholder value. It deliberately contains NO real secret values,
# so the hook itself is safe to commit and push.
#
# Bypass intentionally (not recommended) with:  git commit --no-verify

set -u

# A value is considered a safe PLACEHOLDER (not a secret) if it matches this.
# Extend as needed. Empty values are always fine.
placeholder='^(your-|your\.|example|changeme|xxx|<.*>|.*example\.com).*$'

# Credential fields to police: any assignment of one of these keys to a
# non-empty, non-placeholder value is treated as a real secret.
key_regex='^\+[[:space:]]*(password|card_number|card_cvn|bot_token)[[:space:]]*=[[:space:]]*(.+)$'

# Exclude this hook file itself from the scan.
staged=$(git diff --cached --name-only --diff-filter=ACM -- . ':(exclude)scripts/pre-commit')
[ -z "$staged" ] && exit 0

added=$(git diff --cached -U0 -- $staged | grep -E '^\+' || true)
[ -z "$added" ] && exit 0

hits=""
while IFS= read -r line; do
  if [[ "$line" =~ $key_regex ]]; then
    key="${BASH_REMATCH[1]}"
    val="${BASH_REMATCH[2]}"
    # Trim surrounding whitespace from the value.
    val="$(echo "$val" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    [ -z "$val" ] && continue                          # empty -> fine
    shopt -s nocasematch
    if [[ "$val" =~ $placeholder ]]; then
      shopt -u nocasematch
      continue                                          # placeholder -> fine
    fi
    shopt -u nocasematch
    hits+="  ${key} is set to a non-placeholder value"$'\n'
  fi
done <<< "$added"

if [ -n "$hits" ]; then
  echo "------------------------------------------------------------------"
  echo "COMMIT BLOCKED: a staged change looks like a real secret."
  echo "------------------------------------------------------------------"
  echo "$hits"
  echo "Real credentials belong in config/config.local.ini (gitignored),"
  echo "NOT in config/config.ini. Move the value there and re-commit."
  echo "To bypass intentionally: git commit --no-verify"
  echo "------------------------------------------------------------------"
  exit 1
fi

exit 0
