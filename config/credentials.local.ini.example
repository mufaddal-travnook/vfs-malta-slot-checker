; Multiple VFS accounts, rotated by clock hour.
;
; Copy this file to  config/credentials.local.ini  (gitignored) and fill in real
; accounts. Add as many [credN] sections as you like, in order.
;
; Rotation: cred1 is used at the first run hour of the day (06:00), cred2 at
; 07:00, and so on, wrapping after the last one. Both runs within an hour
; (e.g. :29 and :59) use the same account. All URLs in a run use that account.
;
; If config/credentials.local.ini does not exist, the bot falls back to the
; single [vfs-credential] account in config.ini / config.local.ini.

[cred1]
email = account1@example.com
password = your-password-1

[cred2]
email = account2@example.com
password = your-password-2

[cred3]
email = account3@example.com
password = your-password-3
